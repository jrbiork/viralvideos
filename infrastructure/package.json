{
  "name": "viral-videos-infrastructure",
  "version": "0.1.0",
  "description": "AWS CDK infrastructure for Viral Videos MVP",
  "main": "bin/viral-videos-app.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "npm run build:infrastructure && npm run build:lambda",
    "build:infrastructure": "tsc",
    "build:lambda": "cd lambda/video-generation && npm install && ../../node_modules/.bin/tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "npx cdk deploy",
    "destroy": "cdk destroy",
    "synth": "cdk synth",
    "setup": "chmod +x setup-env.sh && ./setup-env.sh"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.133",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "aws-cdk": "^2.124.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.855.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@runwayml/sdk": "^2.7.0",
    "aws-cdk-lib": "^2.124.0",
    "axios": "^1.6.7",
    "constructs": "^10.3.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.6.1",
    "fluent-ffmpeg": "^2.1.2",
    "openai": "^4.28.0",
    "source-map-support": "^0.5.21"
  }
}
