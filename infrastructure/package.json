{
  "name": "viral-videos-infrastructure",
  "version": "0.1.0",
  "description": "AWS CDK infrastructure for Viral Videos MVP",
  "main": "bin/viral-videos-app.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "npm run build:lambda && npm run build:infrastructure",
    "build:infrastructure": "tsc",
    "build:lambda": "./build-lambda.sh",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy": "npx cdk deploy",
    "destroy": "cdk destroy",
    "synth": "cdk synth",
    "setup": "chmod +x setup-env.sh && ./setup-env.sh"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "aws-cdk": "^2.124.0",
    "esbuild": "^0.25.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.124.0",
    "constructs": "^10.3.0",
    "dotenv": "^16.6.1",
    "source-map-support": "^0.5.21"
  }
}
