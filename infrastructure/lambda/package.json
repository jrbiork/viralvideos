{
  "name": "viral-videos-lambda-functions",
  "version": "1.0.0",
  "description": "Lambda functions for viral videos application",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:video-generation && tsc",
    "build:video-generation": "cd video-generation && tsc",
    "build:full-video-queue": "cd full-video-queue && tsc",
    "build:fetch-videos": "cd fetch-videos && tsc",
    "build:jwt-authorizer": "cd jwt-authorizer && tsc",
    "build:generate-story-breakdown": "cd generate-story-breakdown && tsc",
    "build:generate-audio-subtitle": "cd generate-audio-subtitle && tsc",
    "build:generate-images": "cd generate-images && tsc",
    "build:delete-video": "cd delete-video && tsc",
    "build:websocket-connect": "cd websocket-connect && tsc",
    "build:websocket-disconnect": "cd websocket-disconnect && tsc",
    "build:websocket-message": "cd websocket-message && tsc",
    "build:websocket-broadcast": "cd websocket-broadcast && tsc",
    "build:all": "npm run build:video-generation && npm run build:full-video-queue && npm run build:fetch-videos && npm run build:jwt-authorizer && npm run build:generate-story-breakdown && npm run build:generate-audio-subtitle && npm run build:generate-images && npm run build:delete-video && npm run build:websocket-connect && npm run build:websocket-disconnect && npm run build:websocket-message && npm run build:websocket-broadcast",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.868.0",
    "@aws-sdk/client-sqs": "^3.868.0",
    "@aws-sdk/client-dynamodb": "^3.868.0",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.868.0",
    "@aws-sdk/util-dynamodb": "^3.868.0",
    "@aws-sdk/lib-dynamodb": "^3.868.0",
    "@aws-sdk/s3-request-presigner": "^3.868.0",
    "@runwayml/sdk": "^2.7.0",
    "axios": "^1.6.7",
    "fluent-ffmpeg": "^2.1.2",
    "jose": "^5.10.0",
    "openai": "^4.28.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.133",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
